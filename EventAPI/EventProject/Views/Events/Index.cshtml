@model IEnumerable<EventViewModel>

@{
    ViewData["Title"] = "Događaji";
}
<h2 class="mb-4">Događaji</h2>
<a class="btn btn-primary mb-3" asp-action="Create">Novi događaj</a>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Agenda</th>
            <th>Datum i vreme</th>
            <th>Trajanje (h)</th>
            <th>Cena</th>
            <th>Lokacija</th>
            <th>Tip</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Name</td>
                <td>@d.Agenda</td>
                <td>@d.DateTime.ToString("g")</td>
                <td>@d.DurationInHours</td>
                <td>@d.Price</td>
                <td>@d.LocationName</td>
                <td>@d.TypeName</td>
                <td>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@d.Id">Detalji</a>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@d.Id">Izmeni</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@d.Id">Obriši</a>
                    <a class="btn btn-success btn-sm" asp-controller="EventLectures" asp-action="Index" asp-route-eventId="@d.Id">Predavači</a>
                </td>
            </tr>
        }
    </tbody>
</table>