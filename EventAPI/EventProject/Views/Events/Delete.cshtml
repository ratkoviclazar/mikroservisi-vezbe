@model EventViewModel
@{
    ViewData["Title"] = "Obriši događaj";
}
<h2>Obriši događaj</h2>
<p>Da li ste sigurni da želite da obrišete događaj <strong>@Model.Name</strong>?</p>
<dl class="row">
    <dt class="col-sm-3">Datum i vreme</dt>
    <dd class="col-sm-9">@Model.DateTime.ToString("g")</dd>
    <dt class="col-sm-3">Lokacija</dt>
    <dd class="col-sm-9">@Model.LocationName</dd>
    <dt class="col-sm-3">Tip</dt>
    <dd class="col-sm-9">@Model.TypeName</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>