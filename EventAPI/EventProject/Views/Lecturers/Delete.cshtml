@model LecturerViewModel
@{
    ViewData["Title"] = "Obriši predavača";
}
<h2>Obriši predavača</h2>
<p>Da li ste sigurni da želite da obrišete predavača <strong>@Model.Title @Model.FirstName @Model.LastName</strong>?</p>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>