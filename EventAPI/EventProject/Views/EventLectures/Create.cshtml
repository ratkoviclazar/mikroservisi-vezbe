@model EventLectureViewModel
@{
    ViewData["Title"] = "Dodaj predavača";
}
<h2>Dodaj predavača — @ViewBag.EventName</h2>
<form asp-action="Create" method="post">
    <input type="hidden" asp-for="EventId" />

    <div class="form-group">
        <label asp-for="LecturerId">Predavač</label>
        <select asp-for="LecturerId" class="form-control" asp-items="ViewBag.Lecturers">
            <option value="">-- Izaberite predavača --</option>
        </select>
        <span asp-validation-for="LecturerId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DateTime">Datum i vreme predavanja</label>
        <input asp-for="DateTime" class="form-control" type="datetime-local" />
        <span asp-validation-for="DateTime" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DurationInHours">Trajanje (h)</label>
        <input asp-for="DurationInHours" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="DurationInHours" class="text-danger"></span>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false)
        </div>
    }

    <button type="submit" class="btn btn-primary">Sačuvaj</button>
    <a asp-action="Index" asp-route-eventId="@Model.EventId" class="btn btn-secondary">Nazad</a>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}